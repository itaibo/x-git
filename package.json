{
  "name": "@itaibo/x-git",
  "version": "0.1.1",
  "type": "module",
  "description": "Git commands for x",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@type-x/types": "0.2.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.2"
  },
  "x": {
    "runtime": "1",
    "commands": {
      "pull": {
        "entry": "./dist/src/pull.js",
        "description": "Pulls changes from remote repository"
      },
      "push": {
        "entry": "./dist/src/push.js",
        "description": "Pushes changes to the current branch"
      },
      "new": {
        "entry": "./dist/src/new.js",
        "description": "Creates a new branch"
      }
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
